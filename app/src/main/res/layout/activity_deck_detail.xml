<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingTop="100dp"
    android:paddingLeft="28dp"
    android:paddingRight="28dp"
    android:paddingBottom="28dp">


    <TextView
        android:id="@+id/textDeckName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="?attr/colorOnSurface"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textDeckDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/textCardCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="?attr/colorPrimary"
        android:textSize="14sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        android:background="?attr/colorOutline" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonOralComprehension"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:padding="16dp"
        android:text="Practice Oral Comprehension" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonVoiceTest"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:padding="16dp"
        android:text="Practice Pronunciation" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonExpression"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:padding="16dp"
        android:text="Practice Oral Expression" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonCreateCard"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:padding="16dp"
        android:text="Create a new card" />

</LinearLayout>